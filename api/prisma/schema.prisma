// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Quartos {
  id       Int        @id @default(autoincrement())
  numero   Int        @unique
  tipo     String?
  reservas Reservas[]
}

model Reservas {
  id           Int       @id @default(autoincrement())
  hospede      String?
  data_entrada DateTime  @default(now())
  data_saida   DateTime?
  quarto_id    Int
  quarto       Quartos   @relation(fields: [quarto_id], references: [id])
}
